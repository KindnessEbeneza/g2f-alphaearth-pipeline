cat > .gitignore <<'EOF'
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Virtual env
.venv/

# Data and generated outputs
data/outputs/
data/real/
data/sample/merged_pheno.csv
data/experiments/
configs/_tmp_*.yaml

# Credentials/secrets
.credentials/
*.json
.env

# VS Code / OS
.vscode/
.DS_Store
EOF